class DIINABlock(nn.Module):
def __init__(self, d_model, n_heads, context_dim):
super(DIINABlock, self).__init__()
self.dir_module = DynamicInhibitoryRegulator(d_model, context_dim)
self.inh_attention = InhibitionAugmentedAttention(d_model, n_heads)
self.layernorm = nn.LayerNorm(d_model)
‌
def forward(self, x, context_cues):
w_inh = self.dir_module(x, context_cues)
B_inh = -10.0 * w_inh.unsqueeze(1)
attn_out = self.inh_attention(x, x, x, B_inh=B_inh)
return self.layernorm(x + attn_out)
